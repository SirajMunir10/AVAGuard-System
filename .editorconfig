# Editor configuration, see https://editorconfig.org
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf

[*.py]
indent_size = 4

[*.{html,css,js,json,yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
