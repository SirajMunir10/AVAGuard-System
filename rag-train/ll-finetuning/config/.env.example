# ============================================
# AVAGuard Security AI - API Keys Configuration
# ============================================
# IMPORTANT: This is an EXAMPLE file. Copy it to .env and fill in your keys.
# NEVER commit your real .env file to git — it is already in .gitignore.
#
# HOW TO GET FREE API KEYS:
# ============================================
#
# 1. GOOGLE GEMINI (PRIMARY - 2M tokens/month FREE)
#    → https://aistudio.google.com/apikey
#    → Sign in with Google account → Click "Create API Key"
#    → Free tier: 15 RPM, 1M tokens/min, 1500 req/day
#
# 2. DEEPSEEK (500K tokens FREE on signup)
#    → https://platform.deepseek.com/sign_up
#    → Sign up with email → Go to API Keys → Create key
#
# 3. GROQ (FREE - very fast inference)
#    → https://console.groq.com/keys
#    → Sign up with Google/GitHub → Create API Key
#    → Free tier: 14,400 tokens/min for most models
#
# 4. TOGETHER.AI ($25 FREE credit on signup)
#    → https://api.together.ai/settings/api-keys
#
# 5. ANTHROPIC CLAUDE ($5 FREE credit)
#    → https://console.anthropic.com/settings/keys
#
# 6. MISTRAL AI (Free tier available)
#    → https://console.mistral.ai/api-keys/
#
# 7. OPENAI ($5 FREE credit for new accounts)
#    → https://platform.openai.com/api-keys
#
# 8. COHERE (Free trial key - 1000 calls/month)
#    → https://dashboard.cohere.com/api-keys
#
# 9. OPENROUTER (some models free)
#    → https://openrouter.ai/keys
#
# 10. HUGGING FACE (Free inference API)
#     → https://huggingface.co/settings/tokens
#
# ============================================

# Primary Providers (Highest Free Tier)
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Secondary Providers (Free Credits)
TOGETHER_API_KEY=your_together_api_key_here
CLAUDE_API_KEY=your_anthropic_claude_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Additional Free Providers
COHERE_API_KEY=your_cohere_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
HF_API_KEY=your_huggingface_api_key_here

# ============================================
# MULTI-ACCOUNT SUPPORT
# ============================================
# To scale beyond single-account limits, add extra keys.
# Format: PROVIDER_API_KEY_2, PROVIDER_API_KEY_3, etc.
# The system auto-rotates through keys when quota is hit.
#
# ── Gemini (create multiple Google Cloud projects for separate quotas) ──
# GEMINI_API_KEY_2=your_second_gemini_key
# GEMINI_API_KEY_3=your_third_gemini_key
#
# ── Groq ──
# GROQ_API_KEY_2=your_second_groq_key
#
# ── Mistral ──
# MISTRAL_API_KEY_2=your_second_mistral_key
#
# ── Cohere ──
# COHERE_API_KEY_2=your_second_cohere_key
#
# ── OpenRouter ──
# OPENROUTER_API_KEY_2=your_second_openrouter_key
#
# ── HuggingFace ──
# HF_API_KEY_2=your_second_hf_key
