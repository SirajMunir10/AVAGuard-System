# ============================================
# AVAGuard Web Portal - Environment Config
# ============================================
# Copy this file to .env and customize as needed:
#   cp .env.example .env

# Django
SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT Signing Key (MUST differ from SECRET_KEY in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# In development, falls back to SECRET_KEY automatically.
# JWT_SIGNING_KEY=your-separate-jwt-signing-key

# ── Database ──
# Default: SQLite (no config needed — just works)
# For Supabase/PostgreSQL: uncomment and fill in below
#
# DB_ENGINE=postgresql
# DB_NAME=postgres
# DB_USER=postgres.YOUR_PROJECT_REF
# DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
# DB_HOST=aws-0-us-east-1.pooler.supabase.com
# DB_PORT=6543
# DB_SSLMODE=require

# Email (leave blank to use console backend — OTP codes print to terminal)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# OTP / 2FA (set to True to enforce OTP on login)
# When False: OTP middleware is skipped, 2FA UI is hidden, no email config needed
OTP_ENABLED=False

# ── Redis Cache (Production) ──
# When set, rate limiting uses Redis (survives restarts, works with gunicorn)
# When empty, falls back to in-memory cache (development only)
# REDIS_URL=redis://localhost:6379/0

# ── Upload Limits ──
# Maximum request body size (bytes). Default: 10MB
# DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
# Maximum number of check results per scan upload
# SCAN_UPLOAD_MAX_RESULTS=500

# Web portal CORS origins
PORTAL_CORS_ORIGIN=http://localhost:8000
PORTAL_CORS_ORIGIN_ALT=http://127.0.0.1:8000
