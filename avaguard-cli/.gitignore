# ============================================================================  
# AVAGuard Security-Critical .gitignore  
# ============================================================================  

# ========================  
# CRITICAL: Credentials & Secrets  
# ========================  
config/settings.yaml           # Contains Azure credentials
config/settings.local.yaml
config/*.local.yaml
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
secrets.json
credentials.json
service-account.json

# Azure Key Vault secrets cache
.azure/
.azcli/

# Token caches
.token_cache
*.token
token_cache.bin
msal_token_cache.json

# ========================  
# Sensitive Data Files  
# ========================  
# Database files (contains scan results)
database/*.db
database/*.sqlite
database/*.sqlite3
*.db
*.sqlite
*.sqlite3

# Mock data with real info (if you modify it)
AVAMockData.json              # Keep default mock, ignore real data if modified

# Backup files
*.bak
*.backup
*.old

# ========================  
# Logs & Reports  
# ========================  
logs/
*.log
reports/
*.html
*.pdf
*.json.report

# PowerShell logs
powershell/logs/
*.ps1.log

# ========================  
# Python  
# ========================  
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# Distribution / packaging
build/
dist/
*.egg-info/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# ========================  
# IDEs & Editors  
# ========================  
# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.ipr
*.iws

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ========================  
# Operating Systems  
# ========================  
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# ========================  
# Temporary / Cache Files  
# ========================  
*.tmp
*.temp
*.cache
.~lock.*

# ========================  
# Node.js / Web Dashboard  
# ========================  
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ========================  
# Docker  
# ========================  
.dockerignore
docker-compose.override.yml

# ========================  
# CI/CD Secrets  
# ========================  
.github/secrets/
.gitlab-ci-secrets/

# ========================  
# Custom AVAGuard Files  
# ========================  
# Test output
test_results/
test_reports/

# Performance profiling
*.prof
*.lprof

# ========================  
# Keep These Template Files  
# ========================  
!config/settings.yaml.example
!AVAMockData.json.example
!.env.example

# ========================  
# Additional Local / Project Exclusions  
# ========================  
config.ini
*.secret
output/
combine_project_code.py
combined_code.txt
combined_checks_code.txt
combined_project_code.txt
structure.txt
project.doc
